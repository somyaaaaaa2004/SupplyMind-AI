# ============================================================
# SupplyMind AI – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Application -----
NODE_ENV="development"           # development | staging | production
PORT=5000
APP_NAME="SupplyMind AI API"
API_VERSION="v1"
CLIENT_URL="http://localhost:3000"

# ----- MongoDB -----
MONGODB_URI="mongodb://localhost:27017/supplymind_dev"
# MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/supplymind?retryWrites=true&w=majority"

# ----- Prisma (Mongo connector) -----
DATABASE_URL="mongodb://localhost:27017/supplymind_dev"

# ----- JWT -----
JWT_ACCESS_SECRET="replace_with_a_long_random_string_access"
JWT_REFRESH_SECRET="replace_with_a_long_random_string_refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- Redis -----
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
# REDIS_URL="redis://:password@localhost:6379/0"

# ----- CORS -----
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ----- File Uploads -----
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,application/pdf,text/csv"

# ----- Email (Nodemailer) -----
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@supplymind.ai"

# ----- AI Service (Python microservice – future) -----
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY=""

# ----- Monitoring (optional) -----
# SENTRY_DSN=""
# LOG_LEVEL="info"              # error | warn | info | http | debug
