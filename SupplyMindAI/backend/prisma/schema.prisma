// SupplyMind AI – Prisma Schema (MongoDB)
// Run: npx prisma generate
// Run: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  PROCUREMENT_MANAGER
  INVENTORY_MANAGER
  LOGISTICS_COORDINATOR
  FINANCE_ANALYST
  VIEWER
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT_TO_SUPPLIER
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELAYED
  EXCEPTION
  RETURNED
  CANCELLED
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  RETURN
  WRITE_OFF
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  PENDING_REVIEW
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  logoUrl     String?
  industry    String?
  country     String?
  currency    String    @default("USD")
  timezone    String    @default("UTC")
  plan        String    @default("starter")
  isActive    Boolean   @default(true)
  metadata    Json?

  // Relations
  users           User[]
  purchaseOrders  PurchaseOrder[]
  suppliers       Supplier[]
  inventoryItems  InventoryItem[]
  warehouses      Warehouse[]
  shipments       Shipment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("organizations")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole  @default(VIEWER)
  avatarUrl      String?
  isActive       Boolean   @default(true)
  isEmailVerified Boolean  @default(false)
  lastLoginAt    DateTime?
  metadata       Json?

  // Relations
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

// ─── Supplier ─────────────────────────────────────────────────────────────────

model Supplier {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  code           String
  status         SupplierStatus @default(ACTIVE)
  email          String?
  phone          String?
  website        String?
  country        String?
  address        Json?          // { street, city, state, zip, country }
  contactPerson  String?
  paymentTerms   Int?           // days
  currency       String         @default("USD")
  taxId          String?
  rating         Float?         // 0–5 score
  tags           String[]
  metadata       Json?

  // Relations
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])
  purchaseOrders PurchaseOrder[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@map("suppliers")
}

// ─── Purchase Order ───────────────────────────────────────────────────────────

model PurchaseOrder {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  poNumber        String
  status          PurchaseOrderStatus @default(DRAFT)
  totalAmount     Float
  currency        String              @default("USD")
  expectedDelivery DateTime?
  notes           String?
  lineItems       Json                // Array of { skuId, description, qty, unitPrice, total }
  approvedBy      String?
  approvedAt      DateTime?
  metadata        Json?

  // Relations
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])
  supplierId     String       @db.ObjectId
  supplier       Supplier     @relation(fields: [supplierId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, poNumber])
  @@map("purchase_orders")
}

// ─── Inventory Item ───────────────────────────────────────────────────────────

model InventoryItem {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  sku            String
  name           String
  description    String?
  category       String?
  unit           String  @default("pcs")
  unitCost       Float?
  reorderPoint   Int     @default(0)
  reorderQty     Int     @default(0)
  stockQty       Int     @default(0)
  reservedQty    Int     @default(0)
  imageUrl       String?
  barcode        String?
  tags           String[]
  metadata       Json?

  // Relations
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, sku])
  @@map("inventory_items")
}

// ─── Warehouse ────────────────────────────────────────────────────────────────

model Warehouse {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String
  address     Json?
  coordinates Json?   // { lat, lng }
  capacity    Int?
  isActive    Boolean @default(true)
  metadata    Json?

  // Relations
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@map("warehouses")
}

// ─── Shipment ─────────────────────────────────────────────────────────────────

model Shipment {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  trackingNumber  String?
  carrier         String?
  status          ShipmentStatus @default(PENDING)
  origin          Json?          // { address, coordinates }
  destination     Json?
  estimatedArrival DateTime?
  actualArrival   DateTime?
  weight          Float?
  dimensions      Json?          // { length, width, height, unit }
  metadata        Json?

  // Relations
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("shipments")
}
