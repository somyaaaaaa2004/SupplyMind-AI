# ============================================================
# SupplyMind AI – Docker Compose Environment Variables
# Copy to .env in this directory (docker/.env) and fill in values.
# ============================================================

# ----- MongoDB -----
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_me_strong_password

# ----- Redis -----
REDIS_PASSWORD=change_me_redis_password

# ----- JWT (production) -----
JWT_ACCESS_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_64_char_different_random_string

# ----- URLs -----
CLIENT_URL=https://app.supplymind.ai
NEXT_PUBLIC_API_URL=https://api.supplymind.ai
ALLOWED_ORIGINS=https://app.supplymind.ai

# ----- Mapbox -----
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# ----- Production DB (MongoDB Atlas or managed) -----
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/supplymind?retryWrites=true
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/supplymind?retryWrites=true
# REDIS_URL=redis://:password@redis.host:6379/0

# ----- Image tag (CI/CD) -----
IMAGE_TAG=latest
