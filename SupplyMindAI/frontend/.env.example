# ============================================================
# SupplyMind AI – Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----- Application -----
NEXT_PUBLIC_APP_NAME="AUTONOMOUS PROCUREMENT AND LOGISTICS BRAIN"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development"   # development | staging | production

# ----- API -----
NEXT_PUBLIC_API_URL="http://localhost:5000"
NEXT_PUBLIC_API_VERSION="v1"

# ----- Mapbox -----
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your_mapbox_public_token_here"

# ----- Feature Flags -----
NEXT_PUBLIC_ENABLE_AI_FEATURES="true"
NEXT_PUBLIC_ENABLE_ANALYTICS="false"

# ----- Analytics (optional) -----
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ----- Monitoring (optional) -----
# NEXT_PUBLIC_SENTRY_DSN=""
